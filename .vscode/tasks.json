{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "dotnet: clean",
            "type": "process",
            "command": "dotnet",
            "args": [
                "clean",
                "${workspaceFolder}/MX.TravelItinerary.sln"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "dotnet: build",
            "type": "process",
            "command": "dotnet",
            "args": [
                "build",
                "${workspaceFolder}/MX.TravelItinerary.sln"
            ],
            "dependsOn": "dotnet: clean",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "dotnet: test",
            "type": "process",
            "command": "dotnet",
            "args": [
                "test",
                "${workspaceFolder}/MX.TravelItinerary.sln",
                "--filter",
                "FullyQualifiedName!~IntegrationTests"
            ],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "dotnet: format",
            "type": "process",
            "command": "dotnet",
            "args": [
                "format",
                "${workspaceFolder}/MX.TravelItinerary.sln",
                "--verify-no-changes"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "dotnet: run-web",
            "type": "process",
            "command": "dotnet",
            "args": [
                "run",
                "--project",
                "${workspaceFolder}/src/MX.TravelItinerary.Web/MX.TravelItinerary.Web.csproj"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "dependsOn": "dotnet: build",
            "problemMatcher": "$msCompile",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        }
    ]
}